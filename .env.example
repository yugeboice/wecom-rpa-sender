# === 企业微信 RPA 配置 ===
# 企业微信窗口标题关键字（用于激活窗口）
WECOM_WINDOW_TITLE=企业微信

# RPA 操作间隔（秒）
RPA_STEP_DELAY=0.5
RPA_SEARCH_WAIT=1.0
RPA_SEND_WAIT=0.5

# 任务重试
MAX_RETRY_COUNT=3
RETRY_DELAY_SECONDS=30

# 定时任务扫描间隔（秒）
SCHEDULER_INTERVAL=5

# 数据库
DATABASE_URL=sqlite:///./data/tasks.db

# 截图保存
SCREENSHOT_DIR=./screenshots

# 日志
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
